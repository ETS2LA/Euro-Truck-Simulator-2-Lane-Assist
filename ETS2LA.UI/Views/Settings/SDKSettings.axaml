<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ETS2LA.UI.Views.Settings"
             x:Class="ETS2LA.UI.Views.Settings.SDKSettings"
             x:DataType="views:SDKSettings">
    <StackPanel>
        <TextBlock Text="SDK Settings Page" />
        <TextBlock Text="This version of ETS2LA can't yet handle SDK installation. You can use the python version to do that, both versions use the same SDK." Classes="Description" />
    </StackPanel>
</UserControl>