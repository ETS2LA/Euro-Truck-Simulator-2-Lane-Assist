{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console) - Windows",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-windows",
            "program": "${workspaceFolder}/ETS2LA/bin/Debug/net10.0/ETS2LA.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ETS2LA/bin/Debug/net10.0",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Launch (console) - Linux",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-linux",
            "program": "${workspaceFolder}/ETS2LA/bin/Debug/net10.0/ETS2LA",
            "args": [],
            "cwd": "${workspaceFolder}/ETS2LA/bin/Debug/net10.0",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "OPENTK_4_USE_WAYLAND": "0"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ],
}